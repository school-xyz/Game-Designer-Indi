  locationSprite: {fileID: 21300000, guid: 1248a6e3def8f0d43806730ee272fb08, type: 3}
  speakerName: "\u0410\u043A\u0438\u0440\u0430"
  dialogueText: "\u0421\u043B\u0443\u0448\u0430\u0439\u2026 \u043C\u043E\u0436\u0435\u0448\u044C
    \u0441\u0445\u043E\u0434\u0438\u0442\u044C \u0432 \u043C\u0430\u0433\u0430\u0437\u0438\u043D
    \u0443 \u043F\u043B\u043E\u0449\u0430\u0434\u0438? \u041D\u0430\u043C \u043D\u0443\u0436\u0435\u043D
    \u0445\u043B\u0435\u0431 \u0438 \u0447\u0430\u0439.  \u0422\u043E\u043B\u044C\u043A\u043E
    \u043D\u0435 \u043F\u0435\u0440\u0435\u043F\u043B\u0430\u0442\u0438 \u043E\u043F\u044F\u0442\u044C,
    \u043B\u0430\u0434\u043D\u043E?"
  choices:
  - text: "\xAB\u041A\u043E\u043D\u0435\u0447\u043D\u043E, \u0431\u0435\u0437 \u043F\u0440\u043E\u0431\u043B\u0435\u043C.\xBB"
