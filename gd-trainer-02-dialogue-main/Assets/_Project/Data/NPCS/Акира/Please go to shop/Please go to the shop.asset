    condition:
      conditionType: 0
      requiredValue: 0
      flagName: 
    effect:
      conditionType: 2
      choiceEffectType: 0
      value: 1
  - text: "\xAB\u0410 \u043F\u043E\u0447\u0435\u043C\u0443 \u0441\u0430\u043C\u0430
      \u043D\u0435 \u0441\u0445\u043E\u0434\u0438\u0448\u044C?\xBB"
    reactionSprite: {fileID: 21300000, guid: c2f1fcd8ca7388e478443b60bbc74536, type: 3}
    nextNode: {fileID: 11400000, guid: 1c79a6a0efffdec48a3491b80d0ee98b, type: 2}
    condition:
